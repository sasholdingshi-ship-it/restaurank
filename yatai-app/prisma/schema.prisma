generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Ingredient {
  id          Int     @id @default(autoincrement())
  ref         Int     @unique
  name        String
  supplier    String?
  priceTtc    Float?
  priceHt     Float?
  weight      Float?
  pricePerKg  Float?
  lossPercent Float   @default(0)
  netPriceKg  Float?
  recipeIngredients RecipeIngredient[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Recipe {
  id           Int     @id @default(autoincrement())
  ref          String  @unique
  name         String
  category     String?
  unit         String?
  portions     Float?
  portionLabel String?
  laborTime    Float?
  aleaPercent  Float   @default(0.02)
  margin       Float?
  costPerUnit  Float?
  sellingPrice Float?
  ingredients RecipeIngredient[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecipeIngredient {
  id           Int  @id @default(autoincrement())
  recipeId     Int
  ingredientId Int?
  ingredientRef Int?
  quantity     Float @default(0)
  unitPrice    Float @default(0)
  amount       Float @default(0)
  unit         String?
  notes        String?
  recipe     Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient? @relation(fields: [ingredientId], references: [id])
  @@index([recipeId])
}

model Product {
  id           Int     @id @default(autoincrement())
  ref          String  @unique
  name         String
  priceHt      Float?
  unit         String?
  orderItems OrderItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Restaurant {
  id            Int     @id @default(autoincrement())
  code          String  @unique
  name          String
  arrondissement String
  siren         String?
  deliveryPrice Float   @default(25)
  tvaRate       Float   @default(0.055)
  orders Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id           Int    @id @default(autoincrement())
  restaurantId Int
  year         Int
  month        Int
  nbPassages   Int    @default(0)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  items      OrderItem[]
  @@unique([restaurantId, year, month])
  @@index([restaurantId])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id        Int   @id @default(autoincrement())
  orderId   Int
  productId Int
  day       Int
  quantity  Float @default(0)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  @@unique([orderId, productId, day])
  @@index([orderId])
  @@index([productId])
}

model SmicConfig {
  id          Int   @id @default(autoincrement())
  hourlyRate  Float
  monthlyRate Float?
  effectiveDate DateTime?
}
