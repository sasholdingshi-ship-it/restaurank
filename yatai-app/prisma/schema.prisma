generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Ingredient {
  id          Int     @id @default(autoincrement())
  ref         Int     @unique
  name        String
  supplier    String?
  priceTtc    Float?
  priceHt     Float?
  weight      Float?
  pricePerKg  Float?
  lossPercent Float   @default(0)
  netPriceKg  Float?
  recipeIngredients RecipeIngredient[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Recipe {
  id           Int     @id @default(autoincrement())
  ref          String  @unique
  name         String
  category     String?
  unit         String?
  portions     Float?
  portionLabel String?
  laborTime    Float?
  aleaPercent  Float   @default(0.02)
  margin       Float?
  costPerUnit  Float?
  sellingPrice Float?
  ingredients RecipeIngredient[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecipeIngredient {
  id           Int  @id @default(autoincrement())
  recipeId     Int
  ingredientId Int?
  ingredientRef Int?
  quantity     Float @default(0)
  unitPrice    Float @default(0)
  amount       Float @default(0)
  unit         String?
  notes        String?
  recipe     Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient? @relation(fields: [ingredientId], references: [id])
  @@index([recipeId])
}

model Product {
  id           Int     @id @default(autoincrement())
  ref          String  @unique
  name         String
  priceHt      Float?
  unit         String?
  orderItems OrderItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Restaurant {
  id            Int     @id @default(autoincrement())
  code          String  @unique
  name          String
  arrondissement String
  siren         String?
  deliveryPrice Float   @default(25)
  tvaRate       Float   @default(0.055)
  orders Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id             Int    @id @default(autoincrement())
  restaurantId   Int
  year           Int
  month          Int
  nbPassages     Int    @default(0)
  stuartPrice    Float  @default(0)
  stuartQty      Int    @default(0)
  livraisonPrice Float  @default(0)
  livraisonQty   Int    @default(0)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  items      OrderItem[]
  extras     OrderExtra[]
  @@unique([restaurantId, year, month])
  @@index([restaurantId])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderExtra {
  id       Int    @id @default(autoincrement())
  orderId  Int
  type     String
  label    String @default("")
  price    Float  @default(0)
  quantity Int    @default(0)
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  @@index([orderId])
}

model OrderItem {
  id        Int    @id @default(autoincrement())
  orderId   Int
  productId Int
  day       Int
  quantity  Float  @default(0)
  unitPrice Float?
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  @@unique([orderId, productId, day])
  @@index([orderId])
  @@index([productId])
}

model SmicConfig {
  id          Int   @id @default(autoincrement())
  hourlyRate  Float
  monthlyRate Float?
  effectiveDate DateTime?
}

model MonthlyExpense {
  id     Int    @id @default(autoincrement())
  year   Int
  month  Int
  type   String
  amount Float  @default(0)
  @@unique([year, month, type])
}

model ZeltySale {
  id           Int      @id @default(autoincrement())
  year         Int
  month        Int
  restaurantId Int      // Yatai Restaurant.id (mapped from Zelty id_restaurant)
  zeltyId      Int      // Original Zelty restaurant id
  totalHT      Float    @default(0)  // sum of final_amount_exc_tax (in €)
  totalTTC     Float    @default(0)  // sum of final_amount_inc_tax (in €)
  ordersCount  Int      @default(0)
  eatInTTC     Float    @default(0)
  takeawayTTC  Float    @default(0)
  deliveryTTC  Float    @default(0)
  syncedAt     DateTime @default(now())
  @@unique([year, month, restaurantId])
  @@index([year, month])
}

model ZeltyDishSale {
  id            Int      @id @default(autoincrement())
  year          Int
  month         Int
  restaurantId  Int      // Yatai Restaurant.id
  zeltyItemId   Int      // Zelty dish item_id (catalog id, stable across orders)
  name          String   // Zelty dish name
  quantity      Int      @default(0)  // total units sold this month
  yataiProductRef String?  // mapped Yatai Product.ref (if matched)
  syncedAt      DateTime @default(now())
  @@unique([year, month, restaurantId, zeltyItemId])
  @@index([year, month])
  @@index([yataiProductRef])
}

// BOM for customer-facing dishes sold via Zelty POS.
// Sourced from the "Coût Plat" Excel sheet + manually-added à la carte items.
// One DishBom per dish (e.g. "Ramen Tradi base"), with ingredients that reference
// labo products (e.g. "Bouillon Porc") by name.
model DishBom {
  id                 Int       @id @default(autoincrement())
  name               String    @unique             // e.g. "Ramen Tradi base"
  category           String                        // "DONBURI" | "RAMEN" | "TAPAS" | "DESSERT" | "ALA_CARTE"
  zeltyKeywords      String    @default("[]")      // JSON array of keywords to match Zelty dish names
  isALaCarte         Boolean   @default(false)
  ingredients        DishBomIngredient[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model DishBomIngredient {
  id                    Int     @id @default(autoincrement())
  dishBomId             Int
  name                  String               // e.g. "Bouillon Porc", "Œuf Mollet"
  qtyPerPortion         Float   @default(0)  // quantity consumed per portion sold (kg, unit, etc.)
  unit                  String?              // "kg", "unit", "L"
  yataiProductKeywords  String  @default("[]") // JSON array of keywords to match Yatai Rekki product names
  dishBom               DishBom @relation(fields: [dishBomId], references: [id], onDelete: Cascade)
  @@index([dishBomId])
}

// Generic snapshot system for data rollback.
// Stores a JSON dump of an entity at a point in time so we can restore
// after a mistake (bad edit, bad import, accidental delete).
model Snapshot {
  id        Int      @id @default(autoincrement())
  entity    String   // "DishBom", "Recipe", "Ingredient", etc.
  label     String   // Human label: "Avant import", "Auto-save avant edit X", etc.
  data      String   // JSON dump of all rows for that entity
  createdAt DateTime @default(now())
  @@index([entity, createdAt])
}
